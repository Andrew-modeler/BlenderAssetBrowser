# =============================================================================
# Что НЕ грузить в репозиторий.
# Правило простое: всё, что можно пересоздать командой Build, — мусор.
# =============================================================================

# --- Артефакты сборки Unreal Engine ---
# Папки, которые UE регенерирует при каждой сборке. Они огромные и бесполезные
# для других людей — у каждого они будут свои.
Binaries/
Intermediate/
Saved/
DerivedDataCache/
Build/

# --- Дебаг-символы (.pdb) ---
# 60–300 МБ каждый. Нужны только для отладки крашей у себя локально.
# Если кто-то захочет отлаживать — он соберёт их сам.
*.pdb

# --- Сгенерированные проекты IDE ---
*.sln
*.suo
*.user
*.VC.db
*.VC.opendb

# --- Файлы редакторов ---
.vs/
.vscode/
.idea/
*.swp
*.swo
*~

# --- Системный мусор ОС ---
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# --- Локальные логи нашего проекта (не интересны другим) ---
build*.log
build_log.txt
editor_test*.log

# --- Python bytecode caches (создаются Blender'ом при запуске addon'а) ---
__pycache__/
*.pyc

# --- Локальное состояние Claude Code ---
.claude/

# --- Тестовый UE-проект (личная песочница, не часть плагина) ---
# Плагин нужно дропать в свой собственный проект — это нормальная UE-практика.
# Если хочешь поделиться примером — выложишь его отдельно.
TestProject/

# --- Одноразовые конфиги для gh api ---
branch-protection.json
